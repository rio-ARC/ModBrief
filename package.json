{
  "name": "modbrief",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && npm run build:server",
    "build:client": "vite build",
    "build:server": "npx esbuild src/server/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/server/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@devvit/web": "0.12.23",
    "hono": "^4.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "license": "BSD-3-Clause"
}